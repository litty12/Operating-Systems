#include<stdio.h>
#include<pthread.h>
#include<semaphore.h>

sem_t wrt, mutex, readTry, wmutex;
int readcount = 0, writecount = 0;

void *reader(void *arg)
{
    sem_wait(&readTry);
    sem_wait(&mutex);

    readcount++;
    if(readcount == 1)
        sem_wait(&wrt);

    sem_post(&mutex);
    sem_post(&readTry);

    printf("Reader is reading\n");

    sem_wait(&mutex);
    readcount--;

    if(readcount == 0)
        sem_post(&wrt);

    sem_post(&mutex);
}

void *writer(void *arg)
{
    sem_wait(&wmutex);
    writecount++;

    if(writecount == 1)
        sem_wait(&readTry);

    sem_post(&wmutex);

    sem_wait(&wrt);

    printf("Writer is writing\n");

    sem_post(&wrt);

    sem_wait(&wmutex);
    writecount--;

    if(writecount == 0)
        sem_post(&readTry);

    sem_post(&wmutex);
}

int main()
{
    pthread_t r1,r2,w1;

    sem_init(&wrt,0,1);
    sem_init(&mutex,0,1);
    sem_init(&readTry,0,1);
    sem_init(&wmutex,0,1);

    pthread_create(&r1,NULL,reader,NULL);
    pthread_create(&r2,NULL,reader,NULL);
    pthread_create(&w1,NULL,writer,NULL);

    pthread_join(r1,NULL);
    pthread_join(r2,NULL);
    pthread_join(w1,NULL);

    return 0;
}